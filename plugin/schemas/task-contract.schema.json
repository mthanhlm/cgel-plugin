{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgel.dev/schemas/task-contract.schema.json",
  "title": "CGEL Task Contract (Phase 0)",
  "description": "Reference schema. The shipped validator is hand-rolled (stdlib only) but mirrors these constraints.",
  "type": "object",
  "required": ["task", "acceptance_criteria", "scope"],
  "properties": {
    "task": {
      "type": "object",
      "required": ["id", "type", "goal"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"},
        "type": {"type": "string", "minLength": 1},
        "goal": {"type": "string", "minLength": 1}
      }
    },
    "domains": {
      "type": "object",
      "properties": {
        "primary": {"type": "string"},
        "additional": {"type": "array", "items": {"type": "string"}}
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "required_checks": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "scope": {
      "type": "object",
      "required": ["allowed"],
      "properties": {
        "allowed": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "forbidden": {"type": "array", "items": {"type": "string"}},
        "notes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "protected_capabilities": {
      "type": "array",
      "items": {"type": "string"},
      "description": "e.g. modify-governance, modify-verification-registry, modify-hook-policy, modify-evaluation-baseline, external-write, dependency-change, schema-migration, public-api-change"
    },
    "budgets": {
      "type": "object",
      "properties": {
        "max_iterations": {"type": "integer", "minimum": 1, "default": 5},
        "max_replans": {"type": "integer", "minimum": 0, "default": 2}
      }
    },
    "risk": {
      "type": "object",
      "properties": {
        "level": {"enum": ["low", "medium", "high"], "default": "low"},
        "reasons": {"type": "array", "items": {"type": "string"}}
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target", "approved_by", "reason"],
        "properties": {
          "target": {"type": "string", "description": "RULE-ID being excepted"},
          "approved_by": {"type": "string"},
          "reason": {"type": "string"},
          "scope": {"type": "string"},
          "expires_at": {"type": "string"}
        }
      }
    },
    "ai": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "affected_components": {"type": "array", "items": {"type": "string"}},
        "behavior_invariants": {"type": "array", "items": {"type": "string"}}
      }
    },
    "intent_review": {
      "type": "object",
      "description": "Outcome of the pre-seal design challenge: what was questioned about the user's requested approach, and what was chosen. Expected (warned when absent) for medium/high risk.",
      "properties": {
        "assessed": {"type": "boolean"},
        "concerns": {"type": "array", "items": {"type": "string"}},
        "alternative_chosen": {"type": "string"}
      }
    }
  }
}
