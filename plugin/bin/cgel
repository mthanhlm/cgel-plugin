#!/usr/bin/env python3
"""cgel — CGEL CLI: contract lifecycle (draft -> validate -> summary -> seal)
plus the Phase 1 evidence pipeline (verify -> audit -> evidence-gated PASS).

Output contract: one machine-parseable decision line on stdout (last line);
details and failures on stderr. Exit 0 = ok, 1 = denied/failed, 3 = usage.

Profile A honesty: this CLI packages logic; it is NOT a trust boundary.
The human anchor for a seal is the user approving the exact `cgel seal
<task> --digest sha256:...` command (permission prompt or typing it).
Evidence records are hash-chained: tamper-EVIDENT, never tamper-proof.
"""

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import traceback

PLUGIN_ROOT = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
sys.path.insert(0, os.path.join(PLUGIN_ROOT, "scripts"))
import cgel_common as C

# CGEL adds nothing to a host project's history: the runtime mirror and the
# registry both stay local. The registry being local means each clone starts
# with no checks and must register its own before any evidence can exist.
GITIGNORE_ENTRIES = (".cgel/", ".task/")
# Emptied so the harness never authors an AI-attribution trailer — the half of
# the no-attribution guarantee the command-string guard structurally cannot see.
ATTRIBUTION_KEYS = ("commit", "pr", "sessionUrl")


def fail(line, *details):
    for detail in details:
        print(detail, file=sys.stderr)
    print(line)
    return 1


def ok(line, *details):
    for detail in details:
        print(detail, file=sys.stderr)
    print(line)
    return 0


def require_repo_root():
    root = C.find_repo_root(os.getcwd())
    if not root:
        print(
            "cgel: no .cgel/ directory found in this directory or any parent. "
            "Run `cgel init` at the project root first.",
            file=sys.stderr,
        )
        print("ERROR no-cgel-project")
        sys.exit(3)
    return root


def load_contract(repo_root, override=None):
    """Default draft is .task/contract.json; --contract names another file
    (still under .task/, the always-writable area) so two DRAFTS can exist
    at once — the second parallel task drafts at .task/<id>.contract.json."""
    path = os.path.join(repo_root, override) if override else os.path.join(
        repo_root, C.CONTRACT_REL_PATH
    )
    try:
        return C.load_json(path), path
    except FileNotFoundError:
        return None, path
    except Exception as exc:
        print("cgel: %s is not valid JSON: %s" % (path, exc), file=sys.stderr)
        return None, path


def _draft_paths(repo_root):
    """Contract drafts on disk: .task/contract.json and .task/*.contract.json."""
    base = os.path.join(repo_root, ".task")
    paths = []
    try:
        names = sorted(os.listdir(base))
    except OSError:
        return paths
    for name in names:
        if name == "contract.json" or name.endswith(".contract.json"):
            paths.append(os.path.join(base, name))
    return paths


def _draft_warnings(repo_root, contract):
    """Say at draft time what would otherwise surface at close time —
    an AC without checks structurally cannot PASS, and in real use that
    turned 8 of 12 closes into ESCALATE."""
    c = C.normalize_contract(contract)
    registry, _ = C.load_registry(repo_root)
    known = set((registry.get("checks") or {}).keys())
    warnings = []
    for item in c["acceptance_criteria"]:
        checks = item.get("required_checks") or []
        if not checks:
            warnings.append(
                "%s has no required_checks — PASS will be impossible; name a "
                "check (register one with `cgel check add` before sealing) "
                "or plan to close as ESCALATE" % item["id"]
            )
        for check_id in checks:
            if known and check_id not in known:
                warnings.append(
                    "%s requires unregistered check '%s' (registered: %s)"
                    % (item["id"], check_id, ", ".join(sorted(known)))
                )
    if c["risk"]["level"] in ("medium", "high") and not isinstance(
        contract.get("intent_review"), dict
    ):
        warnings.append(
            "no intent_review — medium/high risk work records the "
            "design-challenge outcome (concerns, alternative_chosen) before "
            "sealing; see the cgel:task skill"
        )
    return warnings

def resolve_task_or_fail(repo_root, task_arg, verb):
    """Shared --task resolution; prints the denial and returns None on miss."""
    task, error = C.resolve_task(repo_root, task_arg or None)
    if task is None:
        print("%s DENIED — %s" % (verb, error))
        return None
    return task


# ---------------------------------------------------------------- commands

def _merge_attribution_settings(root):
    """Set attribution.{commit,pr,sessionUrl}="" in .claude/settings.json.

    The command guard only ever sees an inline `git commit -m "..."`; a message
    from $EDITOR or `--body-file` never reaches the Bash string, so the guard
    cannot touch it. `attribution.<k>: ""` closes that at the harness itself,
    for every path. Non-destructive: a value the user already set is left alone,
    a malformed settings.json is reported and never clobbered, and a run that
    changes nothing writes nothing (idempotent).
    """
    settings_path = os.path.join(root, ".claude", "settings.json")
    settings = {}
    if os.path.isfile(settings_path):
        try:
            with open(settings_path, encoding="utf-8") as fh:
                settings = json.load(fh)
            if not isinstance(settings, dict):
                raise ValueError("settings.json is not a JSON object")
        except Exception as exc:
            C._debug("init:settings", exc)
            print(
                "cgel: .claude/settings.json is unreadable (%s) — left untouched. "
                'Add {"attribution": {"commit": ""}} yourself to stop the harness '
                "adding an AI trailer to commits/PRs." % exc,
                file=sys.stderr,
            )
            return
    attribution = settings.get("attribution")
    if not isinstance(attribution, dict):
        attribution = {}
    added = [k for k in ATTRIBUTION_KEYS if k not in attribution]
    if not added:
        return
    for key in added:
        attribution[key] = ""
    settings["attribution"] = attribution
    try:
        C.atomic_write_json(settings_path, settings)
    except Exception as exc:
        C._debug("init:settings-write", exc)
        print(
            "cgel: could not write .claude/settings.json (%s) — set "
            'attribution.commit="" yourself.' % exc,
            file=sys.stderr,
        )
        return
    print(
        'cgel: set attribution.%s="" in .claude/settings.json so commits/PRs '
        "carry no AI trailer." % "/".join(added),
        file=sys.stderr,
    )


def cmd_init(_args):
    root = os.getcwd()
    cgel_dir = os.path.join(root, ".cgel")
    task_dir = os.path.join(root, ".task")
    already = os.path.isdir(cgel_dir)
    os.makedirs(cgel_dir, exist_ok=True)
    os.makedirs(task_dir, exist_ok=True)
    config_path = os.path.join(cgel_dir, "config.json")
    if not os.path.isfile(config_path):
        C.atomic_write_json(config_path, {"gate": "on", "git_guard": "on"})
    registry_path = os.path.join(root, C.REGISTRY_REL_PATH)
    if not os.path.isfile(registry_path):
        C.atomic_write_json(
            registry_path,
            {
                "checks": {},
                "_doc": "verification registry — check-id: {command, "
                "timeout_seconds, working_directory, success:{exit_code}, kind}",
            },
        )
    gitignore = os.path.join(root, ".gitignore")
    try:
        existing = ""
        if os.path.isfile(gitignore):
            with open(gitignore, encoding="utf-8") as fh:
                existing = fh.read()
        lines = existing.splitlines()
        missing = [entry for entry in GITIGNORE_ENTRIES if entry not in lines]
        if missing:
            with open(gitignore, "a", encoding="utf-8") as fh:
                if existing and not existing.endswith("\n"):
                    fh.write("\n")
                for entry in missing:
                    fh.write(entry + "\n")
    except Exception as exc:
        C._debug("init:gitignore", exc)
        print(
            "cgel: could not update .gitignore — add %s manually."
            % " and ".join("'%s'" % entry for entry in GITIGNORE_ENTRIES),
            file=sys.stderr,
        )
    _merge_attribution_settings(root)
    if already:
        return ok("INIT OK — already initialized (gate on)")
    return ok("INIT OK — .cgel/ and .task/ created and gitignored, gate on")


def cmd_validate(args):
    root = require_repo_root()
    contract, path = load_contract(root, args.contract)
    if contract is None:
        return fail(
            "VALIDATE FAIL — no readable contract",
            "cgel: expected a contract draft at %s" % path,
        )
    errors = C.validate_contract(contract)
    if errors:
        for error in errors:
            print("  - %s" % error, file=sys.stderr)
        return fail("VALIDATE FAIL — %d error(s)" % len(errors))
    for warning in _draft_warnings(root, contract):
        print("  warn: %s" % warning, file=sys.stderr)
    task_id = contract["task"]["id"]
    return ok("VALIDATE PASS — %s digest %s" % (task_id, C.contract_digest(contract)))


def _intent_review_lines(contract):
    review = contract.get("intent_review")
    if not isinstance(review, dict):
        return []
    lines = []
    concerns = review.get("concerns") or []
    lines.append("Design review: %d concern(s) recorded" % len(concerns))
    lines += ["  - %s" % concern for concern in concerns]
    if review.get("alternative_chosen"):
        lines.append("  chosen: %s" % review["alternative_chosen"])
    return lines


def cmd_summary(args):
    root = require_repo_root()
    contract, path = load_contract(root, args.contract)
    if contract is None:
        return fail("SUMMARY FAIL — no readable contract", "cgel: expected %s" % path)
    errors = C.validate_contract(contract)
    if errors:
        for error in errors:
            print("  - %s" % error, file=sys.stderr)
        return fail("SUMMARY FAIL — contract invalid (%d error(s))" % len(errors))
    for warning in _draft_warnings(root, contract):
        print("  warn: %s" % warning, file=sys.stderr)

    c = C.normalize_contract(contract)
    digest = C.contract_digest(contract)

    claimed = (contract.get("risk") or {}).get("level")
    floored = c["risk"]["level"] != claimed
    lines = [
        "Task: %s (%s)" % (c["task"]["id"], c["task"]["type"]),
        "Goal: %s" % c["task"]["goal"],
        "Risk: %s%s"
        % (
            c["risk"]["level"],
            " (raised from '%s' — see below)" % claimed if floored else "",
        ),
    ]
    lines += ["  - %s" % reason for reason in c["risk"]["reasons"]]
    lines += _intent_review_lines(contract)
    lines.append("Allowed scope:")
    lines += ["  - %s" % p for p in c["scope"]["allowed"]]
    if c["scope"]["forbidden"]:
        lines.append("Forbidden paths:")
        lines += ["  - %s" % p for p in c["scope"]["forbidden"]]
    lines.append("Protected capabilities: %s" % (
        ", ".join(c["protected_capabilities"]) or "none"
    ))
    lines.append("Acceptance criteria:")
    for item in c["acceptance_criteria"]:
        checks = ", ".join(item.get("required_checks", [])) or "none listed"
        lines.append("  - %s: %s (checks: %s)" % (item["id"], item["description"], checks))
    lines.append("Budgets: %d iterations, %d replans" % (
        c["budgets"]["max_iterations"], c["budgets"]["max_replans"]
    ))
    if contract.get("exceptions"):
        # Retired. It was in the schema, printed here at the seal ceremony,
        # and named by CGEL-DEBT-1 as the only legitimate way to accept debt
        # — and read by nothing: blocking_count consulted only the rules file
        # and the verifier was never told. A user approved a waiver that had
        # no effect. Warn rather than ignore: a contract still carrying it
        # was written against a promise that never held.
        lines.append(
            "WARNING: `exceptions` is retired and was never read by anything "
            "— remove it. To accept a rule's finding, say so in the "
            "iteration's decision and close honestly."
        )
    # The verdict, on the screen where the user approves the digest.
    # _semantic_requirement was computed at seal and NOWHERE else, so the
    # summary said "Risk: low" and never mentioned that low means nothing
    # will grade this work. A user cannot consent to a bar they were not
    # shown. Same function the seal freezes, so the screen and the seal
    # cannot disagree.
    semantic = _semantic_requirement(contract, C.load_semantic_rules(root))
    if semantic["required"]:
        lines.append(
            "Semantic verification: REQUIRED (%s)" % "; ".join(semantic["reasons"])
        )
        lines.append(
            "  the read-only verifier will judge this change against: %s"
            % ", ".join(semantic["blocking_rule_ids"])
        )
        lines.append("  a blocking finding stops PASS.")
    else:
        lines.append(
            "Semantic verification: NOT REQUIRED at risk.level=%s — no rule "
            "will judge this change and no finding can stop PASS. Only the "
            "registered checks grade it." % c["risk"]["level"]
        )
    for line in lines:
        print(line, file=sys.stderr)

    return ok(
        "SUMMARY %s digest=%s semantic=%s"
        % (c["task"]["id"], digest, "required" if semantic["required"] else "none")
    )


def _semantic_requirement(contract, rules):
    """Frozen at seal (D: trigger frozen). Deterministic, no model judgement."""
    c = C.normalize_contract(contract)
    reasons = []
    if c["risk"]["level"] == "high":
        reasons.append("risk.level=high")
    if (c.get("ai") or {}).get("enabled"):
        reasons.append("ai.enabled")
    if c.get("semantic_review") is True:
        reasons.append("contract.semantic_review=true")
    blocking = sorted(r["id"] for r in rules.values() if r["blocking"])
    if blocking and c["risk"]["level"] == "medium":
        reasons.append("blocking rules present at risk.level=medium")
    return {
        "required": bool(reasons),
        "reasons": reasons,
        "blocking_rule_ids": blocking,
    }


def _dirty_paths_intersecting_scope(repo_root, allowed_patterns):
    try:
        proc = subprocess.run(
            # quotePath is pinned so a user's git config cannot change what
            # this parser sees; errors="replace" so a path this locale cannot
            # decode degrades one path, never the whole guard.
            [
                "git",
                "-c",
                "core.quotePath=true",
                "status",
                "--porcelain",
                "--untracked-files=all",
            ],
            cwd=repo_root,
            capture_output=True,
            encoding="utf-8",
            errors="replace",
            timeout=15,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        # Returning [] means "nothing uncommitted", which is exactly what a
        # caller wants to hear and the one thing we cannot honestly say. Say
        # out loud that the guard did not run.
        C._debug("seal:git-status", exc)
        print(
            "cgel: git status could not be read (%s) — the uncommitted-work "
            "guard did NOT run for this command." % exc,
            file=sys.stderr,
        )
        return []
    if proc.returncode != 0:
        return []  # not a git repo — nothing to protect via git
    hits = []
    for line in proc.stdout.splitlines():
        if len(line) < 4:
            continue
        path = line[3:]
        if " -> " in path:
            path = path.split(" -> ", 1)[1]
        path = path.strip().strip('"')
        if path.startswith(".task/"):
            continue
        if C.path_matches(path, allowed_patterns):
            hits.append(path)
    return hits


def _rotate_closed_task_dir(task_dir, task_id):
    """A fresh seal of a previously closed id must not inherit that run's
    spent budgets or chains — archive the old directory instead.

    Returns None when the id is clear to seal, or a reason string when it is
    not. Every failure here used to return None, which reads as "clear" — so
    an unreadable or unmovable previous run was silently inherited: its
    evidence chain became the new task's, and its spent budgets came with it.
    A seal that cannot prove the id is clean must fail closed."""
    state_path = os.path.join(task_dir, "state.json")
    if not os.path.isfile(state_path):
        return None
    try:
        state = C.load_json(state_path)
    except Exception as exc:
        C._debug("seal:rotate", exc)
        return "state.json in %s is unreadable (%s)" % (task_dir, exc)
    if not isinstance(state, dict):
        # Valid JSON of the wrong shape: state.get() below would raise, and
        # before the main() guard that was a bare traceback at seal time.
        return "state.json in %s is not a JSON object" % task_dir
    if state.get("lifecycle") in C.TASK_LIFECYCLES:
        return None  # still open — the reseal path owns this case
    stamp = re.sub(r"[^0-9TZ]", "", state.get("closed_at") or C.utc_now())[:15]
    target = "%s-closed-%s" % (task_dir, stamp)
    suffix = 0
    while os.path.exists(target):
        suffix += 1
        target = "%s-closed-%s-%d" % (task_dir, stamp, suffix)
    try:
        os.rename(task_dir, target)
    except OSError as exc:
        C._debug("seal:rotate-rename", exc)
        return "could not archive the previous closed run as %s (%s)" % (
            os.path.basename(target),
            exc,
        )
    print(
        "cgel: previous closed run of %s archived as %s."
        % (task_id, os.path.basename(target)),
        file=sys.stderr,
    )
    return None


def cmd_seal(args):
    root = require_repo_root()
    contract, path = load_contract(root, args.contract)
    if contract is None:
        return fail("SEAL DENIED — no readable contract", "cgel: expected %s" % path)
    errors = C.validate_contract(contract)
    if errors:
        for error in errors:
            print("  - %s" % error, file=sys.stderr)
        return fail("SEAL DENIED — contract invalid (%d error(s))" % len(errors))

    c = C.normalize_contract(contract)
    task_id = c["task"]["id"]
    if args.task_id != task_id:
        return fail(
            "SEAL DENIED — task id mismatch",
            "cgel: contract is %s, you asked to seal %s" % (task_id, args.task_id),
        )

    digest = C.contract_digest(contract)
    if args.digest != digest:
        return fail(
            "SEAL DENIED — digest mismatch",
            "cgel: the contract changed after the summary was shown.",
            "cgel: current digest is %s" % digest,
            "cgel: re-run `cgel summary`, show it to the user, and seal the new digest.",
        )

    # Several tasks may be open at once (D-39). Resealing THIS task stays the
    # amendment path; sealing a DIFFERENT task no longer waits for the first
    # to close — it only warns when the scopes overlap.
    opens = C.open_tasks(root)
    mine = next((t for t in opens if t["task_id"] == task_id), None)
    others = [t for t in opens if t["task_id"] != task_id]
    reseal = mine is not None

    store = C.repo_state_dir(root)
    task_dir = os.path.join(store, task_id)
    if not reseal:
        # Say it at the point of no return, not only at the two commands the
        # user may never have run. `_draft_warnings` fired at validate and
        # summary — both optional, both discardable — and stayed silent at
        # the one irreversible act.
        for warning in _draft_warnings(root, contract):
            print("cgel: warn: %s" % warning, file=sys.stderr)
        rot_error = _rotate_closed_task_dir(task_dir, task_id)
        if rot_error is not None:
            return fail(
                "SEAL DENIED — stale task directory for %s" % task_id,
                "cgel: %s" % rot_error,
                "cgel: a previous run of this id left state that cannot be "
                "archived; sealing now would inherit its evidence chain and "
                "spent budgets. Move or repair %s, or seal under a new task "
                "id." % task_dir,
            )

    dirty = _dirty_paths_intersecting_scope(root, c["scope"]["allowed"])
    if reseal:
        # An amendment happens mid-flight, so the task's own in-scope edits are
        # necessarily uncommitted — counting them as the user's work would make
        # --allow-dirty mandatory on the one path the design prescribes. Only
        # what the previous seal did NOT authorise can still be someone else's.
        prior_allowed = mine["sealed"]["contract"]["scope"]["allowed"]
        dirty = [p for p in dirty if not C.path_matches(p, prior_allowed)]
    claimed = []
    for other in others:
        other_allowed = other["sealed"]["contract"]["scope"]["allowed"]
        hits = [p for p in dirty if C.path_matches(p, other_allowed)]
        if hits:
            claimed.extend(hits)
            dirty = [p for p in dirty if p not in hits]
    if claimed:
        print(
            "cgel: %d uncommitted file(s) belong to other open task(s) and "
            "stay their work." % len(claimed),
            file=sys.stderr,
        )
    if dirty and not args.allow_dirty:
        for hit in dirty[:20]:
            print("  dirty: %s" % hit, file=sys.stderr)
        return fail(
            "SEAL DENIED — uncommitted changes intersect scope.allowed",
            "cgel: these files are the user's work. Ask the user; with their "
            "explicit confirmation reseal with --allow-dirty.",
        )

    overlapping = [
        other["task_id"]
        for other in others
        if C.scopes_overlap(
            c["scope"]["allowed"],
            other["sealed"]["contract"]["scope"]["allowed"],
        )
    ]
    if overlapping:
        print(
            "cgel: WARNING — scope.allowed overlaps open task(s) %s. Shared "
            "paths mean shared evidence staleness; keep parallel scopes "
            "disjoint when you can." % ", ".join(overlapping),
            file=sys.stderr,
        )

    bundle = C.governance_bundle(root)
    workspace = C.workspace_snapshot(root)
    semantic = _semantic_requirement(contract, C.load_semantic_rules(root))
    C.atomic_write_json(
        os.path.join(task_dir, "sealed_task.json"),
        {
            "task_id": task_id,
            "contract": c,
            "contract_digest": digest,
            "sealed_at": C.utc_now(),
            "dirty_ack": bool(dirty),
            "governance_bundle": bundle,
            "workspace": workspace,
            "semantic_verification": semantic,
        },
    )
    state_fields = {
        "task_id": task_id,
        "lifecycle": "SEALED",
        "contract_digest": digest,
        "sealed_at": C.utc_now(),
    }
    if reseal:
        # Amending a contract must not quietly take back budget the user
        # granted with `cgel unblock`. Only the user widens a budget, and only
        # the user should narrow one.
        for key in ("budget_extra_iterations", "budget_extra_replans"):
            carried = mine["state"].get(key)
            if carried:
                state_fields[key] = carried
    C.atomic_write_json(os.path.join(task_dir, "state.json"), state_fields)
    try:
        # Legacy pointer: installed hooks one release behind read CURRENT to
        # find the task; without it they see NO_TASK and block every edit
        # during the upgrade window. New code ignores it; close removes it.
        with open(os.path.join(store, "CURRENT"), "w", encoding="utf-8") as fh:
            fh.write(task_id + "\n")
    except OSError as exc:
        C._debug("seal:legacy-current", exc)

    details = [
        "cgel: edits are now allowed inside scope.allowed. Governance paths "
        "stay read-only unless a protected capability grants them.",
        "cgel: governance bundle sealed (%d files). Changing any of them "
        "mid-task moves the task to BLOCKED." % len(bundle["members"]),
    ]
    if others:
        details.append(
            "cgel: %d other task(s) open (%s) — pass --task on every verb."
            % (len(others), ", ".join(o["task_id"] for o in others))
        )
    return ok(
        "SEAL OK — %s digest=%s governance=%s%s"
        % (
            task_id,
            digest,
            bundle["digest"],
            " (reseal)" if reseal else "",
        ),
        *details
    )


# ------------------------------------------------------- evidence pipeline

def _bundle_changed(root, task):
    """True if the governance bundle moved after seal (task goes BLOCKED)."""
    sealed_bundle = (task.get("sealed") or {}).get("governance_bundle")
    if not sealed_bundle:
        return False
    current = C.governance_bundle(root)
    if current["digest"] == sealed_bundle["digest"]:
        return False
    for change in C.bundle_diff(sealed_bundle.get("members"), current["members"])[:20]:
        print("  bundle %s" % change, file=sys.stderr)
    C.set_blocked(root, task["task_id"], "sealed-guidebook-bundle-changed")
    return True


_FAIL_LINE = re.compile(r"(fail|error|assert|panic|exception)", re.I)
_KIND_BY_CHECK = {
    "test": "test_assertion",
    "build": "build",
    "compile": "compile",
    "lint": "lint",
    "typecheck": "typecheck",
    "security": "security",
    "eval": "test_assertion",
}


def _classify_failure(check, exit_code, timed_out, output):
    if timed_out:
        kind = "timeout"
    elif exit_code == 127:
        kind = "command_unavailable"
    elif exit_code == 126:
        kind = "permission_denied"
    else:
        kind = _KIND_BY_CHECK.get(check.get("kind"), "unknown")
    lines = [ln.strip() for ln in output.splitlines() if ln.strip()]
    matched = [ln for ln in lines if _FAIL_LINE.search(ln)]
    subject = (matched[0] if matched else (lines[-1] if lines else ""))[:160]
    normalized = re.sub(r"\d+", "N", "\n".join(matched[:10]).lower())
    fingerprint = (
        C.sha256_bytes(normalized.encode("utf-8"))[:23] if normalized else None
    )
    return kind, subject, fingerprint


# A check's output is captured to a temp file as BYTES and decoded with
# errors="replace" at the end. Two reasons, both load-bearing:
#   - text=True made a check that emits non-UTF-8 raise UnicodeDecodeError
#     (a ValueError) out of _run_check, past every handler, before
#     chain_append — recording no evidence at all, and leaving no record
#     saying a record was missing.
#   - a check is free to produce gigabytes; capture_output holds it all in
#     memory. The cap keeps the head (the failure is usually announced) and
#     the tail (the summary line), and records what was produced, not what
#     was retained.
MAX_CAPTURE_BYTES = 1 << 20
CAPTURE_HEAD_BYTES = 256 << 10
CAPTURE_TAIL_BYTES = MAX_CAPTURE_BYTES - CAPTURE_HEAD_BYTES


def _read_capture(fh):
    """Read a check's capture file. Returns (text, total_bytes, truncated).

    total_bytes is what the check PRODUCED; text may be shorter."""
    fh.flush()
    total = fh.seek(0, os.SEEK_END)
    if total <= MAX_CAPTURE_BYTES:
        fh.seek(0)
        raw = fh.read()
        truncated = False
    else:
        fh.seek(0)
        head = fh.read(CAPTURE_HEAD_BYTES)
        fh.seek(total - CAPTURE_TAIL_BYTES)
        tail = fh.read(CAPTURE_TAIL_BYTES)
        dropped = total - CAPTURE_HEAD_BYTES - CAPTURE_TAIL_BYTES
        raw = head + b"\n... [%d bytes dropped] ...\n" % dropped + tail
        truncated = True
    return raw.decode("utf-8", "replace"), total, truncated


def _summarize(output, head=400, tail=900):
    if len(output) <= head + tail:
        return output
    return (
        output[:head]
        + "\n... [%d characters truncated] ...\n" % (len(output) - head - tail)
        + output[-tail:]
    )


def _verify_preflight(root, task, verb="VERIFY"):
    """Shared refusals before any check may run. Returns an exit code or None."""
    if task["lifecycle"] == "BLOCKED":
        return fail(
            "%s DENIED — task %s is BLOCKED (%s)"
            % (verb, task["task_id"], task["state"].get("blocked_reason", "?")),
            "cgel: resolve the block first (reseal or user action).",
        )
    if not task["sealed"].get("governance_bundle"):
        return fail(
            "%s DENIED — task sealed before the evidence pipeline" % verb,
            "cgel: close and reseal to bind a governance bundle.",
        )
    if _bundle_changed(root, task):
        return fail(
            "%s BLOCKED — sealed-guidebook-bundle-changed" % verb,
            "cgel: registry/rules/hooks/guidebook changed after seal; the "
            "sealed measure is void and the task is BLOCKED.",
            "cgel: reseal to adopt the new measure (`cgel summary` then "
            "`cgel seal %s --digest <same or new>`) — the same digest needs "
            "no new approval — or close honestly." % task["task_id"],
        )
    return None


def _run_check(root, task, check_id, registry, registry_digest):
    """Run one registered check and chain its evidence.

    Returns (status, exit_code, chain_hash, tail_lines); status is 'unknown'
    when the check is not registered (nothing recorded)."""
    check = (registry.get("checks") or {}).get(check_id)
    if not isinstance(check, dict) or not check.get("command"):
        return "unknown", None, None, []
    sealed = task["sealed"]
    command = check["command"]
    timeout = check.get("timeout_seconds", 600)
    workdir = os.path.join(root, check.get("working_directory", "."))
    want_exit = (check.get("success") or {}).get("exit_code", 0)
    started = C.utc_now()
    timed_out = False
    harness_error = None
    # _run_check must be TOTAL: every path below reaches chain_append. An
    # exception escaping here is an unrecorded verification, which is the one
    # failure this pipeline cannot detect after the fact.
    try:
        with tempfile.TemporaryFile() as cap:
            try:
                proc = subprocess.run(
                    command,
                    shell=True,
                    cwd=workdir,
                    stdout=cap,
                    stderr=subprocess.STDOUT,
                    timeout=timeout,
                )
                exit_code = proc.returncode
                output, total_bytes, truncated = _read_capture(cap)
            except subprocess.TimeoutExpired:
                timed_out = True
                exit_code = None
                output, total_bytes, truncated = _read_capture(cap)
                output += "\n[timeout after %ss]" % timeout
            except OSError as exc:
                exit_code = 127
                output = "spawn failed: %s" % exc
                total_bytes = len(output.encode("utf-8", "replace"))
                truncated = False
    except Exception as exc:  # noqa: BLE001 — totality is the point
        C._debug("verify:run", exc)
        harness_error = exc
        exit_code = None
        truncated = False
        output = (
            "cgel: the check could not be run or its output could not be "
            "captured: %s: %s" % (type(exc).__name__, exc)
        )
        total_bytes = len(output.encode("utf-8", "replace"))

    status = (
        "pass"
        if (not timed_out and harness_error is None and exit_code == want_exit)
        else "fail"
    )
    failure_kind = failure_subject = fingerprint = None
    if harness_error is not None:
        # Not the project's failure — the harness's. Kept distinct so the
        # default-same guard cannot read a broken runner as a real regression.
        failure_kind = "harness_error"
        failure_subject = (
            "%s: %s" % (type(harness_error).__name__, harness_error)
        )[:160]
    elif status == "fail":
        failure_kind, failure_subject, fingerprint = _classify_failure(
            check, exit_code, timed_out, output
        )

    tdir = C.task_dir(root, task["task_id"])
    record = {
        "type": "evidence",
        "check": {"id": check_id, "registry_digest": registry_digest},
        "contract_digest": sealed["contract_digest"],
        "governance_digest": sealed["governance_bundle"]["digest"],
        "workspace": C.workspace_snapshot(root),
        "edit_seq": C.count_edit_events(tdir),
        "result": {
            "status": status,
            "exit_code": exit_code,
            "failure_kind": failure_kind,
            "failure_subject": failure_subject,
            "diagnostic_fingerprint": fingerprint,
        },
        "output": {
            # digest covers the RETAINED text; bytes is what the check
            # PRODUCED. They diverge when the output was capped (truncated
            # true) and on timeout, where the marker below is appended after
            # capture. An absent `truncated` key means a record written
            # before the cap existed, whose digest covers the whole output.
            "digest": C.sha256_bytes(output.encode("utf-8", "replace")),
            "bytes": total_bytes,
            "truncated": truncated,
            "summary": _summarize(output),
        },
        "started_at": started,
        "finished_at": C.utc_now(),
    }
    rec = C.chain_append(
        os.path.join(tdir, C.EVIDENCE_FILE), record, C.chain_seed(task["task_id"])
    )
    return status, exit_code, rec["chain"]["hash"][:19], output.splitlines()[-15:]


def _required_check_ids(task):
    """Every required check of every criterion, first mention first."""
    ordered = []
    for criterion in task["sealed"]["contract"]["acceptance_criteria"]:
        for check_id in criterion.get("required_checks") or []:
            if check_id not in ordered:
                ordered.append(check_id)
    return ordered


def cmd_verify(args):
    root = require_repo_root()
    task = resolve_task_or_fail(root, args.task, "VERIFY")
    if task is None:
        return 1
    refused = _verify_preflight(root, task)
    if refused is not None:
        return refused

    registry, registry_digest = C.load_registry(root)
    check_ids = list(args.check_ids)
    if args.required:
        for check_id in _required_check_ids(task):
            if check_id not in check_ids:
                check_ids.append(check_id)
    if not check_ids:
        return fail(
            "VERIFY DENIED — no checks named",
            "cgel: pass one or more check ids, or --required for every "
            "check the contract's criteria name.",
        )
    known = registry.get("checks") or {}
    unknown = [
        check_id
        for check_id in check_ids
        if not isinstance(known.get(check_id), dict)
        or not known.get(check_id, {}).get("command")
    ]
    if unknown:
        return fail(
            "VERIFY DENIED — unknown check '%s'" % "', '".join(unknown),
            "cgel: registered checks: %s"
            % (", ".join(sorted(known.keys())) or "none"),
            "cgel: adding a check edits %s — a governance path; do it before "
            "seal or via a modify-verification-registry task."
            % C.REGISTRY_REL_PATH,
        )

    results = []
    for check_id in check_ids:
        status, exit_code, chain_hash, tail = _run_check(
            root, task, check_id, registry, registry_digest
        )
        results.append((check_id, status, exit_code, chain_hash, tail))
        if len(check_ids) > 1:
            print("  %s: %s (exit=%s)" % (check_id, status, exit_code), file=sys.stderr)

    if len(results) == 1:
        check_id, status, exit_code, chain_hash, tail = results[0]
        line = "VERIFY %s check=%s exit=%s evidence=%s" % (
            status.upper(),
            check_id,
            exit_code,
            chain_hash,
        )
        if status == "pass":
            return ok(line)
        return fail(line, *tail)

    failed = [r for r in results if r[1] != "pass"]
    if not failed:
        return ok(
            "VERIFY PASS — %d/%d checks (%s)"
            % (len(results), len(results), ", ".join(r[0] for r in results))
        )
    details = []
    for check_id, _status, _exit, _hash, tail in failed:
        details.append("cgel: --- %s failing output tail ---" % check_id)
        details.extend(tail)
    return fail(
        "VERIFY FAIL — %d/%d checks failed (%s)"
        % (len(failed), len(results), ", ".join(r[0] for r in failed)),
        *details
    )


def cmd_audit(args):
    root = require_repo_root()
    task = resolve_task_or_fail(root, args.task, "AUDIT")
    if task is None:
        return 1
    task_id = task["task_id"]
    tdir = C.task_dir(root, task_id)
    seed = C.chain_seed(task_id)
    problems, warnings = [], []

    counts = {}
    for name in (C.EVIDENCE_FILE, C.EVENTS_FILE, C.ITERATIONS_FILE, C.SEMANTIC_FILE):
        chain_ok, count, error = C.chain_verify(os.path.join(tdir, name), seed)
        counts[name] = count
        if not chain_ok:
            problems.append("%s: %s" % (name, error))

    sealed = task["sealed"]
    sealed_bundle = sealed.get("governance_bundle")
    if sealed_bundle:
        current = C.governance_bundle(root)
        if current["digest"] != sealed_bundle["digest"]:
            problems.append("governance bundle changed since seal")
            for change in C.bundle_diff(
                sealed_bundle.get("members"), current["members"]
            )[:20]:
                print("  bundle %s" % change, file=sys.stderr)
    else:
        warnings.append("sealed without a governance bundle (pre-Phase-1 seal)")

    evidence = C.read_jsonl(os.path.join(tdir, C.EVIDENCE_FILE))
    stale_seal = 0
    for rec in evidence:
        if rec.get("contract_digest") != sealed.get("contract_digest") or (
            sealed_bundle
            and rec.get("governance_digest") != sealed_bundle.get("digest")
        ):
            stale_seal += 1
    if stale_seal:
        warnings.append(
            "%d evidence record(s) bound to an earlier seal (stale after reseal)"
            % stale_seal
        )

    events = C.read_jsonl(os.path.join(tdir, C.EVENTS_FILE))
    if evidence and not any(e.get("type") == "bash" for e in events):
        warnings.append(
            "no hook-observed `cgel` Bash events — evidence has no independent "
            "anchor (expected when cgel runs outside Claude Code hooks)"
        )

    for warning in warnings:
        print("  warn: %s" % warning, file=sys.stderr)
    if problems:
        return fail("AUDIT FAIL — " + "; ".join(problems))
    return ok(
        "AUDIT OK — evidence=%d events=%d chain=intact bundle=%s warnings=%d"
        % (
            counts[C.EVIDENCE_FILE],
            counts[C.EVENTS_FILE],
            "unchanged" if sealed_bundle else "absent",
            len(warnings),
        )
    )


def _evidence_state(root, task_id):
    """Latest evidence per check id, with the freshness reference points."""
    tdir = C.task_dir(root, task_id)
    latest = {}
    for rec in C.read_jsonl(os.path.join(tdir, C.EVIDENCE_FILE)):
        if rec.get("type") == "evidence":
            latest[(rec.get("check") or {}).get("id")] = rec
    return latest, C.workspace_snapshot(root), C.edit_event_paths(tdir)


def _evidence_problem(rec, check_id, sealed, bundle, snapshot, edit_paths, check_def):
    """Why this check's latest evidence cannot carry a claim, or None.

    PASS and ADVANCE both rest on this one rule, so the two cannot drift into
    disagreeing about what "verified" means.

    A check may declare `watch` globs in the registry: then only changes
    touching a watched path stale its evidence — a README edit no longer
    voids the whole suite's records. No watch (the default) keeps today's
    behavior: any workspace change stales everything. A moved HEAD always
    stales (a commit re-bases every path). The watch list is authored with
    the check and trusted exactly as far as the command itself (D-37).
    """
    if rec is None:
        return "no evidence — run `cgel verify %s`" % check_id
    if (rec.get("result") or {}).get("status") != "pass":
        return "latest evidence is FAIL"
    if (
        rec.get("contract_digest") != sealed["contract_digest"]
        or rec.get("governance_digest") != bundle["digest"]
    ):
        return "evidence bound to a different seal — re-verify"
    watch = (check_def or {}).get("watch") or []
    if (rec.get("workspace") or {}).get("diff_digest") != snapshot["diff_digest"]:
        changed = (
            C.snapshot_changed_paths(rec.get("workspace"), snapshot)
            if watch
            else None
        )
        if changed is None or any(C.path_matches(p, watch) for p in changed):
            return "evidence stale — workspace changed after it was recorded; re-verify"
    recorded_seq = rec.get("edit_seq")
    if recorded_seq != len(edit_paths):
        stale = True
        if watch and isinstance(recorded_seq, int) and 0 <= recorded_seq <= len(
            edit_paths
        ):
            later = edit_paths[recorded_seq:]
            stale = any(C.path_matches(p or "", watch) for p in later)
        if stale:
            return "evidence stale — edits recorded after it; re-verify"
    return None


def _advance_problems(root, task, pending):
    """ADVANCE claims the iteration's own checks passed, so it must prove it.

    Ungated, ADVANCE would be a hole in the default-same guard: fail a check,
    decide ADVANCE instead of the RETRY that would have been refused, and the
    failure travels on wearing a success-shaped label.
    """
    sealed = task["sealed"]
    bundle = sealed.get("governance_bundle")
    if not bundle:
        return ["task sealed before the evidence pipeline — reseal required"]
    checks = pending.get("expected_checks") or []
    if not checks:
        return [
            "the iteration declared no expected_checks — it claimed nothing, so "
            "there is nothing to advance on; decide REPLAN, or reopen the "
            "iteration with --expected-checks"
        ]
    latest, snapshot, edit_paths = _evidence_state(root, task["task_id"])
    registry, _ = C.load_registry(root)
    defs = registry.get("checks") or {}
    problems = []
    for check_id in checks:
        problem = _evidence_problem(
            latest.get(check_id),
            check_id,
            sealed,
            bundle,
            snapshot,
            edit_paths,
            defs.get(check_id),
        )
        if problem:
            problems.append("%s: %s" % (check_id, problem))
    return problems


def _pass_problems(root, task):
    """Everything that must hold before a PASS terminal status (§15.3)."""
    if task["lifecycle"] == "BLOCKED":
        return [
            "task is BLOCKED (%s) — resolve before PASS"
            % task["state"].get("blocked_reason", "?")
        ]
    sealed = task["sealed"]
    bundle = sealed.get("governance_bundle")
    if not bundle:
        return ["task sealed before the evidence pipeline — reseal required"]
    if _bundle_changed(root, task):
        return ["sealed-guidebook-bundle-changed — task moved to BLOCKED; reseal"]

    task_id = task["task_id"]
    tdir = C.task_dir(root, task_id)
    seed = C.chain_seed(task_id)
    problems = []
    for name in (C.EVIDENCE_FILE, C.EVENTS_FILE):
        chain_ok, _, error = C.chain_verify(os.path.join(tdir, name), seed)
        if not chain_ok:
            problems.append("%s: %s (audit failed)" % (name, error))
    if problems:
        return problems

    latest, snapshot, edit_paths = _evidence_state(root, task_id)
    registry, _ = C.load_registry(root)
    defs = registry.get("checks") or {}

    for criterion in sealed["contract"]["acceptance_criteria"]:
        checks = criterion.get("required_checks") or []
        if not checks:
            problems.append(
                "%s: no required_checks — evidence-gated PASS is impossible; "
                "close as ESCALATE (user verifies) or amend + reseal"
                % criterion["id"]
            )
            continue
        for check_id in checks:
            problem = _evidence_problem(
                latest.get(check_id),
                check_id,
                sealed,
                bundle,
                snapshot,
                edit_paths,
                defs.get(check_id),
            )
            if problem:
                problems.append("%s/%s: %s" % (criterion["id"], check_id, problem))

    requirement = sealed.get("semantic_verification") or {}
    if requirement.get("required"):
        semantic = [
            r
            for r in C.read_jsonl(os.path.join(tdir, C.SEMANTIC_FILE))
            if r.get("type") == "semantic"
        ]
        latest = semantic[-1] if semantic else None
        why = ", ".join(requirement.get("reasons", []))
        if latest is None:
            problems.append(
                "semantic verification required (%s) — run the cgel:verifier "
                "subagent and record findings via `cgel semantic record`" % why
            )
        elif (
            latest.get("contract_digest") != sealed["contract_digest"]
            or latest.get("governance_digest") != bundle["digest"]
        ):
            problems.append(
                "semantic findings bound to a different seal — re-run the verifier"
            )
        elif (latest.get("workspace") or {}).get("diff_digest") != snapshot[
            "diff_digest"
        ] or latest.get("edit_seq") != len(edit_paths):
            problems.append(
                "semantic findings stale — workspace changed after the verifier "
                "ran; re-run it"
            )
        elif latest.get("blocking_count", 0) > 0:
            problems.append(
                "%d blocking semantic finding(s) — fix them, or challenge once "
                "with evidence; unresolved disagreement is ESCALATE, never a "
                "silent override" % latest["blocking_count"]
            )
    return problems


# ---------------------------------------------------------------- registry

_CHECK_ID_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$")


def _canary_passes(command, timeout, workdir_hint):
    """Run a check where the project is not. Success there means it is vacuous.

    A check is the measure, and `cgel verify` trusts it completely — so a
    command that cannot fail mints valid evidence for nothing. The cheap,
    general test: a check that depends on the project must break without it.
    `compileall` on a moved path and a glob that matches nothing both exit 0
    here, which is exactly how this repo's own two checks rotted.

    Catches mistakes, not adversaries: a command can be built to fail here and
    still verify nothing, and one using absolute paths is a false positive.
    Returns (vacuous, detail) — vacuous is None when the canary could not run.
    """
    empty = tempfile.mkdtemp(prefix="cgel-canary-")
    try:
        proc = subprocess.run(
            command,
            shell=True,
            cwd=empty,
            capture_output=True,
            encoding="utf-8",
            errors="replace",
            timeout=max(1, min(timeout, 120)),
        )
    except subprocess.TimeoutExpired:
        # A check that hangs without the project is at least depending on
        # something; not vacuous, and not worth waiting out.
        return False, "timed out"
    except Exception as exc:
        C._debug("check:canary", exc)
        return None, "canary could not run"
    finally:
        shutil.rmtree(empty, ignore_errors=True)
    return proc.returncode == 0, "exit %d" % proc.returncode


def _passes_in_tree(command, timeout, workdir, want_exit):
    """Run a check where the project actually is. False means it cannot pass.

    The canary asks 'does this still pass with no project?'; this asks the dual
    'does this pass with the project present?'. A check that fails both is
    neither vacuous nor healthy — its target has moved (deck-compile pointed at
    a deleted deck/) or the project is genuinely broken. The canary is blind to
    this by construction, so doctor has to look.

    Returns (passes, detail). passes is None when the run could not happen.
    """
    try:
        proc = subprocess.run(
            command,
            shell=True,
            cwd=workdir,
            capture_output=True,
            encoding="utf-8",
            errors="replace",
            timeout=max(1, timeout),
        )
    except subprocess.TimeoutExpired:
        return False, "timed out in tree"
    except Exception as exc:
        C._debug("check:tree", exc)
        return None, "could not run in tree"
    return proc.returncode == want_exit, "exit %d" % proc.returncode


def cmd_check(args):
    if args.check_command == "add":
        return cmd_check_add(args)
    if args.check_command == "list":
        return cmd_check_list(args)
    if args.check_command == "doctor":
        return cmd_check_doctor(args)
    if args.check_command == "remove":
        return cmd_check_remove(args)
    print("ERROR usage")
    return 3


def cmd_check_doctor(_args):
    """Re-test every check from both sides. Registration review catches neither.

    The canary catches a check that cannot fail (vacuous). Running the check in
    the tree catches its dual — a check that cannot pass, because its target was
    deleted or renamed. A registry can rot either way, and both leave `verify`
    minting or refusing evidence dishonestly, so a health verdict has to see
    both. DOCTOR OK is earned only when every check fails empty AND passes here.
    """
    root = require_repo_root()
    registry, _ = C.load_registry(root)
    checks = registry.get("checks") or {}
    if not checks:
        return fail(
            "DOCTOR DENIED — no checks registered",
            "cgel: an empty registry measures nothing; add checks with "
            "`cgel check add`.",
        )
    vacuous, broken, unknown = [], [], []
    for check_id in sorted(checks):
        entry = checks[check_id]
        if not isinstance(entry, dict) or not entry.get("command"):
            continue
        command = entry["command"]
        timeout = entry.get("timeout_seconds", 600)
        is_vacuous, canary_detail = _canary_passes(command, timeout, root)
        if is_vacuous is None:
            unknown.append(check_id)
            print("  ? %s — %s" % (check_id, canary_detail), file=sys.stderr)
            continue
        if is_vacuous:
            vacuous.append(check_id)
            print(
                "  VACUOUS %s — passes with no project present (%s): %s"
                % (check_id, canary_detail, command),
                file=sys.stderr,
            )
            continue
        workdir = os.path.join(root, entry.get("working_directory", "."))
        want_exit = (entry.get("success") or {}).get("exit_code", 0)
        passes, tree_detail = _passes_in_tree(command, timeout, workdir, want_exit)
        if passes is None:
            unknown.append(check_id)
            print("  ? %s — %s" % (check_id, tree_detail), file=sys.stderr)
        elif not passes:
            broken.append(check_id)
            print(
                "  CANNOT PASS %s — fails in this project too (%s): %s"
                % (check_id, tree_detail, command),
                file=sys.stderr,
            )
        elif entry.get("unproven"):
            print("  ok %s — registered --allow-unproven, now proven" % check_id,
                  file=sys.stderr)
        else:
            print("  ok %s" % check_id, file=sys.stderr)
    if vacuous or broken:
        parts = []
        if vacuous:
            parts.append(
                "%d check(s) verify nothing: %s" % (len(vacuous), ", ".join(vacuous))
            )
        if broken:
            parts.append(
                "%d check(s) cannot pass here: %s" % (len(broken), ", ".join(broken))
            )
        details = []
        if vacuous:
            details.append(
                "cgel: the vacuous checks pass whether or not the project works — "
                "their evidence is worthless. Repair with `cgel check add <id> "
                "--force --command ...`."
            )
        if broken:
            details.append(
                "cgel: the cannot-pass checks fail here as well as empty. Either "
                "their target moved (rot) or the project is currently broken — "
                "doctor cannot tell which. Fix the project, re-point the check "
                "with `cgel check add <id> --force`, or drop it with `cgel check "
                "remove <id>`."
            )
        return fail("DOCTOR FAIL — %s" % "; ".join(parts), *details)
    return ok(
        "DOCTOR OK — %d check(s) depend on the project%s"
        % (len(checks), " (%d unknown)" % len(unknown) if unknown else "")
    )


def _registry_frozen(root):
    """The registry is sealed inside every open task's governance bundle."""
    tasks = C.open_tasks(root)
    if not tasks:
        return None
    task = tasks[0]
    return fail(
        "CHECK DENIED — task %s is %s; the registry is part of the sealed "
        "governance bundle" % (task["task_id"], task["lifecycle"]),
        "cgel: close the task first, or run a dedicated "
        "modify-verification-registry task.",
    )


def cmd_check_add(args):
    root = require_repo_root()
    frozen = _registry_frozen(root)
    if frozen is not None:
        return frozen
    if not _CHECK_ID_RE.match(args.check_id):
        return fail("CHECK DENIED — invalid check id '%s'" % args.check_id)
    if not args.check_command_str.strip():
        return fail("CHECK DENIED — --command must not be empty")
    registry, _ = C.load_registry(root)
    checks = registry.setdefault("checks", {})
    if args.check_id in checks and not args.force:
        return fail(
            "CHECK DENIED — '%s' already exists (use --force to overwrite)"
            % args.check_id
        )
    command = args.check_command_str.strip()
    entry = {"command": command}
    if args.kind.strip():
        entry["kind"] = args.kind.strip()
    if args.timeout > 0:
        entry["timeout_seconds"] = args.timeout
    if args.workdir.strip():
        entry["working_directory"] = args.workdir.strip()
    watch = [s.strip() for s in args.watch.split(",") if s.strip()]
    if watch:
        entry["watch"] = watch

    vacuous, detail = _canary_passes(command, args.timeout or 600, root)
    if vacuous and not args.allow_unproven:
        return fail(
            "CHECK DENIED — '%s' passes with no project present (%s)"
            % (args.check_id, detail),
            "cgel: this command succeeds in an empty directory, so it cannot "
            "be measuring your project — every `cgel verify` would mint valid "
            "evidence for nothing.",
            "cgel: point it at something that breaks when the project breaks, "
            "or register it anyway with --allow-unproven.",
        )
    if vacuous:
        # The admission belongs on the yardstick, not in a terminal nobody
        # will scroll back to.
        entry["unproven"] = True
    checks[args.check_id] = entry
    C.atomic_write_json(os.path.join(root, C.REGISTRY_REL_PATH), registry)
    details = [
        "cgel: registered in %s. Run it with `cgel verify %s` once a task "
        "is sealed." % (C.REGISTRY_REL_PATH, args.check_id)
    ]
    if vacuous:
        details.append(
            "cgel: recorded `unproven: true` — this check passes without the "
            "project, so evidence from it proves nothing."
        )
    elif vacuous is None:
        details.append("cgel: canary could not run (%s) — check unproven." % detail)
    return ok("CHECK ADDED — %s: %s" % (args.check_id, entry["command"]), *details)


def cmd_check_list(_args):
    root = require_repo_root()
    registry, _ = C.load_registry(root)
    checks = registry.get("checks") or {}
    for check_id in sorted(checks):
        entry = checks[check_id]
        if not isinstance(entry, dict):
            continue
        print(
            "%s: %s%s" % (
                check_id,
                entry.get("command", "?"),
                " (kind: %s)" % entry["kind"] if entry.get("kind") else "",
            ),
            file=sys.stderr,
        )
    return ok("CHECK LIST — %d check(s)" % len(checks))


def cmd_check_remove(args):
    root = require_repo_root()
    frozen = _registry_frozen(root)
    if frozen is not None:
        return frozen
    registry, _ = C.load_registry(root)
    checks = registry.get("checks") or {}
    if args.check_id not in checks:
        known = ", ".join(sorted(checks)) or "none"
        return fail(
            "CHECK DENIED — no check '%s' to remove" % args.check_id,
            "cgel: registered checks: %s" % known,
        )
    del checks[args.check_id]
    C.atomic_write_json(os.path.join(root, C.REGISTRY_REL_PATH), registry)
    return ok(
        "CHECK REMOVED — %s" % args.check_id,
        "cgel: %d check(s) remain." % len(checks),
    )


# ----------------------------------------------------------- semantic layer

def cmd_rules(_args):
    root = require_repo_root()
    rules = C.load_semantic_rules(root)
    for rule in sorted(rules.values(), key=lambda r: r["id"]):
        print(
            "%s%s — %s (%s%s)"
            % (
                rule["id"],
                " [BLOCKING]" if rule["blocking"] else "",
                rule["title"],
                rule["source"],
                ", applies: %s" % ", ".join(rule["applies_to"])
                if rule["applies_to"]
                else "",
            ),
            file=sys.stderr,
        )
    blocking = sum(1 for r in rules.values() if r["blocking"])
    return ok("RULES OK — %d rule(s), %d blocking" % (len(rules), blocking))


def cmd_semantic(args):
    if args.semantic_command != "record":
        print("ERROR usage")
        return 3
    root = require_repo_root()
    task = resolve_task_or_fail(root, args.task, "SEMANTIC")
    if task is None:
        return 1
    if task["lifecycle"] == "BLOCKED":
        return fail(
            "SEMANTIC DENIED — task is BLOCKED (%s)"
            % task["state"].get("blocked_reason", "?")
        )
    sealed = task["sealed"]
    if not sealed.get("governance_bundle"):
        return fail("SEMANTIC DENIED — task sealed before the evidence pipeline")
    if _bundle_changed(root, task):
        return fail("SEMANTIC BLOCKED — sealed-guidebook-bundle-changed; reseal")

    findings_path = args.file or os.path.join(root, ".task", "findings.json")
    try:
        payload = C.load_json(findings_path)
    except FileNotFoundError:
        return fail(
            "SEMANTIC DENIED — no findings file",
            "cgel: expected %s — the main agent writes the verifier "
            "subagent's JSON there." % findings_path,
        )
    except Exception as exc:
        return fail("SEMANTIC DENIED — findings file is not valid JSON: %s" % exc)

    findings = payload.get("findings") if isinstance(payload, dict) else None
    if not isinstance(findings, list):
        return fail(
            "SEMANTIC DENIED — findings file must be "
            '{"findings": [{rule_id, status, confidence, evidence, reason}]}'
        )
    rules = C.load_semantic_rules(root)
    errors, clean = [], []
    for idx, item in enumerate(findings):
        if not isinstance(item, dict):
            errors.append("findings[%d]: must be an object" % idx)
            continue
        rule_id = item.get("rule_id")
        if rule_id not in rules:
            errors.append("findings[%d]: unknown rule_id %r" % (idx, rule_id))
            continue
        status = item.get("status")
        if status not in ("pass", "fail"):
            errors.append("findings[%d]: status must be pass|fail" % idx)
            continue
        confidence = item.get("confidence", 1.0)
        if not isinstance(confidence, (int, float)) or not 0 <= confidence <= 1:
            errors.append("findings[%d]: confidence must be 0..1" % idx)
            continue
        clean.append(
            {
                "rule_id": rule_id,
                "status": status,
                "confidence": confidence,
                "evidence": item.get("evidence") or [],
                "reason": (item.get("reason") or "")[:500],
                "blocking_rule": rules[rule_id]["blocking"],
            }
        )
    if errors:
        for error in errors:
            print("  - %s" % error, file=sys.stderr)
        return fail("SEMANTIC DENIED — %d schema error(s)" % len(errors))

    blocking_count = sum(
        1 for f in clean if f["status"] == "fail" and f["blocking_rule"]
    )
    tdir = C.task_dir(root, task["task_id"])
    record = {
        "type": "semantic",
        "verifier": (payload.get("verifier") if isinstance(payload, dict) else None)
        or "verifier",
        "findings": clean,
        "blocking_count": blocking_count,
        "contract_digest": sealed["contract_digest"],
        "governance_digest": sealed["governance_bundle"]["digest"],
        "workspace": C.workspace_snapshot(root),
        "edit_seq": C.count_edit_events(tdir),
        "at": C.utc_now(),
    }
    C.chain_append(
        os.path.join(tdir, C.SEMANTIC_FILE), record, C.chain_seed(task["task_id"])
    )
    line = "SEMANTIC %s — %d finding(s), %d blocking" % (
        "FAIL" if blocking_count else "OK",
        len(clean),
        blocking_count,
    )
    if blocking_count:
        for f in clean:
            if f["status"] == "fail" and f["blocking_rule"]:
                print("  blocking %s: %s" % (f["rule_id"], f["reason"]), file=sys.stderr)
        return fail(line)
    return ok(line)


def _build_attestation(root, task):
    """Sanitized: ids, statuses, digests — no raw output, no logs."""
    sealed = task["sealed"]
    state = task["state"]
    tdir = C.task_dir(root, task["task_id"])
    latest = {}
    for rec in C.read_jsonl(os.path.join(tdir, C.EVIDENCE_FILE)):
        if rec.get("type") == "evidence":
            latest[(rec.get("check") or {}).get("id")] = rec
    criteria = []
    for criterion in sealed["contract"]["acceptance_criteria"]:
        checks = []
        for check_id in criterion.get("required_checks") or []:
            rec = latest.get(check_id)
            checks.append(
                {
                    "check_id": check_id,
                    "status": (rec.get("result") or {}).get("status")
                    if rec
                    else "missing",
                    "output_digest": (rec.get("output") or {}).get("digest")
                    if rec
                    else None,
                    "recorded_at": rec.get("finished_at") if rec else None,
                }
            )
        criteria.append({"id": criterion["id"], "checks": checks})
    semantic = [
        r
        for r in C.read_jsonl(os.path.join(tdir, C.SEMANTIC_FILE))
        if r.get("type") == "semantic"
    ]
    rule_findings = [
        {"rule_id": f["rule_id"], "status": f["status"], "confidence": f["confidence"]}
        for f in (semantic[-1]["findings"] if semantic else [])
    ]
    iterations = C.iteration_records(tdir)
    decision_counts = {}
    for rec in iterations:
        if rec.get("type") == "iteration_decision":
            key = rec.get("decision")
            decision_counts[key] = decision_counts.get(key, 0) + 1
    return {
        "task_id": task["task_id"],
        "terminal_status": state.get("terminal_status")
        or state.get("lifecycle"),
        "contract_digest": sealed["contract_digest"],
        "governance_digest": (sealed.get("governance_bundle") or {}).get("digest"),
        "semantic_verification": sealed.get("semantic_verification"),
        "criteria": criteria,
        "rule_findings": rule_findings,
        "iterations": {
            "opened": sum(
                1 for r in iterations if r.get("type") == "iteration_open"
            ),
            "decisions": decision_counts,
        },
        "evidence_chain_head": C.chain_head(os.path.join(tdir, C.EVIDENCE_FILE)),
        "events_chain_head": C.chain_head(os.path.join(tdir, C.EVENTS_FILE)),
        "sealed_at": sealed.get("sealed_at"),
        "created_at": C.utc_now(),
    }


def cmd_attest(args):
    root = require_repo_root()
    task = resolve_task_or_fail(root, args.task, "ATTEST")
    if task is None:
        return 1
    # Check the policy BEFORE writing: a refusal that still leaves the
    # artifact on disk is not a refusal. `attestation.persistence` advertised
    # an enum — local | ci-artifact | pr-comment | repository — of which only
    # `local` was ever implemented. A config key that accepts four values and
    # honours one is a control the user is shown that does nothing; reject the
    # three that do not exist rather than accept them and print a footnote.
    policy = (C.read_config(root).get("attestation") or {}).get("persistence")
    if policy is not None and policy != "local":
        return fail(
            "ATTEST DENIED — unknown attestation.persistence '%s'" % policy,
            "cgel: the only implemented policy is `local` (the attestation is "
            "written to the runtime state store, never committed). Remove the "
            "key from .cgel/config.json, or set it to `local`.",
        )
    attestation = _build_attestation(root, task)
    tdir = C.task_dir(root, task["task_id"])
    path = os.path.join(tdir, "attestation", "attestation.json")
    C.atomic_write_json(path, attestation)
    return ok("ATTEST OK — %s" % path)


# ------------------------------------------------------------ loop control

def _budgets(task):
    budgets = task["sealed"]["contract"]["budgets"]
    state = task["state"]
    return (
        budgets["max_iterations"] + state.get("budget_extra_iterations", 0),
        budgets["max_replans"] + state.get("budget_extra_replans", 0),
    )


def cmd_iterate(args):
    if args.iter_command == "open":
        return cmd_iterate_open(args)
    if args.iter_command == "decide":
        return cmd_iterate_decide(args)
    print("ERROR usage")
    return 3


def cmd_iterate_open(args):
    root = require_repo_root()
    task = resolve_task_or_fail(root, args.task, "ITERATE")
    if task is None:
        return 1
    if task["lifecycle"] == "BLOCKED":
        return fail(
            "ITERATE DENIED — task is BLOCKED (%s)"
            % task["state"].get("blocked_reason", "?"),
            "cgel: a user action unblocks it (`cgel unblock ...` or reseal).",
        )
    if not task["sealed"].get("governance_bundle"):
        return fail("ITERATE DENIED — task sealed before the evidence pipeline")
    if _bundle_changed(root, task):
        return fail("ITERATE BLOCKED — sealed-guidebook-bundle-changed; reseal")
    if not args.intended_change.strip():
        return fail(
            "ITERATE DENIED — --intended-change required",
            "cgel: state the smallest change that tests your hypothesis "
            "(alias: --change).",
        )

    tdir = C.task_dir(root, task["task_id"])
    records = C.iteration_records(tdir)
    pending = C.open_iteration(records)
    if pending:
        return fail(
            "ITERATE DENIED — iteration %d has no decision yet"
            % pending["iteration"],
            "cgel: close it first: `cgel iterate decide RETRY|REPLAN|"
            "ROLLBACK_ITERATION`.",
        )
    max_iterations, _ = _budgets(task)
    used = sum(1 for r in records if r.get("type") == "iteration_open")
    if used >= max_iterations:
        C.set_blocked(root, task["task_id"], "budget-exhausted-iterations")
        return fail(
            "ITERATE BLOCKED — iteration budget exhausted (%d/%d)"
            % (used, max_iterations),
            "cgel: budgets never widen silently. The USER can extend: "
            "`cgel unblock --add-iterations <n>` — or close honestly "
            "(ESCALATE/ABORT).",
        )

    number = 1 + max(
        [r.get("iteration", 0) for r in records if r.get("type") == "iteration_open"]
        or [0]
    )
    record = {
        "type": "iteration_open",
        "iteration": number,
        "hypothesis": args.hypothesis.strip() or None,
        "intended_change": args.intended_change.strip(),
        "expected_checks": [
            s.strip() for s in args.expected_checks.split(",") if s.strip()
        ],
        "at": C.utc_now(),
    }
    C.chain_append(
        os.path.join(tdir, C.ITERATIONS_FILE), record, C.chain_seed(task["task_id"])
    )
    if task["lifecycle"] == "SEALED":
        C.update_state(root, task["task_id"], lifecycle="ACTIVE", activated_at=C.utc_now())
    details = []
    if not record["expected_checks"]:
        details.append(
            "cgel: note — no --expected-checks declared, so ADVANCE will be "
            "refused for this iteration; only RETRY/REPLAN/ROLLBACK can close it."
        )
    return ok(
        "ITERATE OPEN — iteration %d/%d task=%s"
        % (number, max_iterations, task["task_id"]),
        *details
    )


DECISIONS = ("ADVANCE", "RETRY", "REPLAN", "ROLLBACK_ITERATION")


def _normalize_decision(raw):
    """Case-insensitive, unique-prefix decision names: ADV, retry, roll — the
    --help round-trips the transcripts are full of were all spelling doubt."""
    text = (raw or "").strip().upper().replace("-", "_")
    if not text:
        return None
    matches = [d for d in DECISIONS if d == text or d.startswith(text)]
    return matches[0] if len(matches) == 1 else None


def cmd_iterate_decide(args):
    root = require_repo_root()
    task = resolve_task_or_fail(root, args.task, "DECIDE")
    if task is None:
        return 1
    if task["lifecycle"] == "BLOCKED":
        return fail(
            "DECIDE DENIED — task is BLOCKED (%s)"
            % task["state"].get("blocked_reason", "?")
        )
    decision = _normalize_decision(args.decision)
    if decision is None:
        return fail(
            "DECIDE DENIED — unknown decision %r" % args.decision,
            "cgel: pick one of %s (unique prefixes work: ADV, RET, REP, ROLL)."
            % "|".join(DECISIONS),
        )
    args.decision = decision
    tdir = C.task_dir(root, task["task_id"])
    records = C.iteration_records(tdir)
    pending = C.open_iteration(records)
    if not pending:
        return fail(
            "DECIDE DENIED — no open iteration",
            "cgel: open one first: `cgel iterate open --intended-change ...` "
            "— or if the work is finished, go straight to `cgel close`.",
        )

    if args.verify:
        # One roundtrip instead of verify-then-decide: freshly run the
        # iteration's own expected checks, recording evidence as `cgel
        # verify` would, then judge the decision against it.
        registry, registry_digest = C.load_registry(root)
        refused = _verify_preflight(root, task, "DECIDE")
        if refused is not None:
            return refused
        for check_id in pending.get("expected_checks") or []:
            status, exit_code, _hash, _tail = _run_check(
                root, task, check_id, registry, registry_digest
            )
            print(
                "  verify %s: %s (exit=%s)" % (check_id, status, exit_code),
                file=sys.stderr,
            )

    if args.decision == "ADVANCE":
        problems = _advance_problems(root, task, pending)
        if problems:
            for problem in problems:
                print("  - %s" % problem, file=sys.stderr)
            return fail(
                "DECIDE DENIED — ADVANCE lacks evidence (%d problem(s))"
                % len(problems),
                "cgel: ADVANCE records that this iteration's hypothesis held; "
                "it is not a route past the failure guard. RETRY or REPLAN.",
            )

    signature = C.latest_failure_signature(tdir)
    sig_key = C.signature_key(signature)
    override = None
    if args.override_reason.strip():
        if not args.approved_by.strip():
            return fail(
                "DECIDE DENIED — failure override needs --approved-by",
                "cgel: overrides are HUMAN_GATED; record who approved it. The "
                "CLI cannot verify a human — the permission prompt is the "
                "real anchor.",
            )
        override = {
            "classify_as_new": True,
            "reason": args.override_reason.strip(),
            "approved_by": args.approved_by.strip(),
        }

    decisions = [r for r in records if r.get("type") == "iteration_decision"]
    same_sig = [
        d
        for d in decisions
        if sig_key is not None
        and C.signature_key(d.get("failure_signature")) == sig_key
        and not (d.get("failure_override") or {}).get("classify_as_new")
    ]

    if args.decision == "RETRY" and sig_key is not None and not override:
        if any(d.get("decision") == "REPLAN" for d in same_sig):
            return fail(
                "DECIDE DENIED — same failure signature survived a REPLAN",
                "cgel: guard default-same: this failure (%s / %s) already "
                "outlived a replan. RETRY and REPLAN are exhausted — "
                "ESCALATE or ABORT." % (signature["check_id"], signature["failure_kind"]),
            )
        if same_sig:
            return fail(
                "DECIDE DENIED — same failure signature seen again; RETRY forbidden",
                "cgel: guard default-same: identical failure (%s / %s) after a "
                "RETRY means the approach, not the execution, is wrong. "
                "Decide REPLAN with a new hypothesis, or override with "
                "user approval (--override-reason ... --approved-by ...)."
                % (signature["check_id"], signature["failure_kind"]),
            )

    if args.decision == "REPLAN":
        _, max_replans = _budgets(task)
        replans_used = sum(1 for d in decisions if d.get("decision") == "REPLAN")
        if replans_used >= max_replans:
            C.set_blocked(root, task["task_id"], "budget-exhausted-replans")
            return fail(
                "DECIDE BLOCKED — replan budget exhausted (%d/%d)"
                % (replans_used, max_replans),
                "cgel: the USER can extend (`cgel unblock --add-replans <n>`) "
                "or the task closes honestly (ESCALATE/ABORT).",
            )

    record = {
        "type": "iteration_decision",
        "iteration": pending["iteration"],
        "decision": args.decision,
        "failure_signature": signature,
        "failure_override": override,
        "lesson": args.lesson.strip() or None,
        "at": C.utc_now(),
    }
    C.chain_append(
        os.path.join(tdir, C.ITERATIONS_FILE), record, C.chain_seed(task["task_id"])
    )
    details = []
    if args.decision == "ROLLBACK_ITERATION":
        details.append(
            "cgel: revert this iteration's patch yourself (git). CGEL never "
            "touches your checkout."
        )
    return ok(
        "DECIDE OK — iteration %d -> %s" % (pending["iteration"], args.decision),
        *details
    )


def cmd_unblock(args):
    root = require_repo_root()
    task = resolve_task_or_fail(root, args.task, "UNBLOCK")
    if task is None:
        return 1
    if task["lifecycle"] != "BLOCKED":
        # Widening a budget BEFORE it runs out is legitimate — refusing it
        # made the user type unblock twice in real use (once too early, once
        # after the block finally landed).
        if args.add_iterations < 1 and args.add_replans < 1:
            return fail(
                "UNBLOCK DENIED — task is not BLOCKED",
                "cgel: to widen a budget before exhaustion, pass "
                "--add-iterations/--add-replans.",
            )
        state = task["state"]
        fields = {}
        if args.add_iterations:
            fields["budget_extra_iterations"] = (
                state.get("budget_extra_iterations", 0) + args.add_iterations
            )
        if args.add_replans:
            fields["budget_extra_replans"] = (
                state.get("budget_extra_replans", 0) + args.add_replans
            )
        C.update_state(root, task["task_id"], **fields)
        return ok(
            "UNBLOCK OK — %s budget extended (iterations +%d, replans +%d); "
            "task stays %s"
            % (
                task["task_id"],
                args.add_iterations,
                args.add_replans,
                task["lifecycle"],
            ),
            "cgel: unblock is a USER action. If the model ran this without "
            "the user's say-so, that is a contract violation — tell the user.",
        )
    reason = task["state"].get("blocked_reason", "?")
    if reason == "sealed-guidebook-bundle-changed":
        return fail(
            "UNBLOCK DENIED — governance bundle changed; only a reseal fixes this",
            "cgel: run `cgel summary` and `cgel seal %s --digest <new>` to "
            "adopt the new measure." % task["task_id"],
        )
    if reason == "budget-exhausted-iterations" and args.add_iterations < 1:
        return fail(
            "UNBLOCK DENIED — blocked on iteration budget; pass --add-iterations <n>"
        )
    if reason == "budget-exhausted-replans" and args.add_replans < 1:
        return fail(
            "UNBLOCK DENIED — blocked on replan budget; pass --add-replans <n>"
        )
    state = task["state"]
    fields = {
        "lifecycle": state.get("lifecycle_before_block", "ACTIVE"),
        "blocked_reason": None,
        "unblocked_at": C.utc_now(),
        "last_block_reason": reason,
    }
    if args.add_iterations:
        fields["budget_extra_iterations"] = (
            state.get("budget_extra_iterations", 0) + args.add_iterations
        )
    if args.add_replans:
        fields["budget_extra_replans"] = (
            state.get("budget_extra_replans", 0) + args.add_replans
        )
    C.update_state(root, task["task_id"], **fields)
    return ok(
        "UNBLOCK OK — %s -> %s (iterations +%d, replans +%d)"
        % (task["task_id"], fields["lifecycle"], args.add_iterations, args.add_replans),
        "cgel: unblock is a USER action. If the model ran this without the "
        "user's say-so, that is a contract violation — tell the user.",
    )


def _status_line(root, task):
    tdir = C.task_dir(root, task["task_id"])
    evidence = [
        r
        for r in C.read_jsonl(os.path.join(tdir, C.EVIDENCE_FILE))
        if r.get("type") == "evidence"
    ]
    extra = " evidence=%d" % len(evidence)
    if task["lifecycle"] == "BLOCKED":
        extra += " reason=%s" % task["state"].get("blocked_reason", "?")
    pending = C.open_iteration(C.iteration_records(tdir))
    if pending:
        extra += " open_iteration=%d" % pending["iteration"]
    return "%s task=%s digest=%s%s" % (
        task["lifecycle"],
        task["task_id"],
        task["state"].get("contract_digest"),
        extra,
    )


def cmd_status(args):
    root = require_repo_root()
    tasks = C.open_tasks(root)
    if args.task:
        tasks = [t for t in tasks if t["task_id"] == args.task]
        if not tasks:
            return fail(
                "STATUS DENIED — no open task '%s'" % args.task,
                "cgel: open tasks: %s"
                % (", ".join(t["task_id"] for t in C.open_tasks(root)) or "none"),
            )
    if not tasks:
        for draft_path in _draft_paths(root):
            try:
                contract = C.load_json(draft_path)
            except Exception:
                continue
            if not C.validate_contract(contract):
                return ok(
                    "STATUS DRAFT task=%s (not sealed)" % contract["task"]["id"]
                )
        return ok("STATUS NO_TASK")
    if len(tasks) == 1:
        return ok("STATUS " + _status_line(root, tasks[0]))
    for task in tasks:
        print("  " + _status_line(root, task), file=sys.stderr)
    return ok(
        "STATUS OPEN — %d task(s): %s (pass --task <id> on every verb)"
        % (len(tasks), ", ".join(t["task_id"] for t in tasks))
    )


def cmd_close(args):
    root = require_repo_root()
    task = resolve_task_or_fail(root, args.task, "CLOSE")
    if task is None:
        return 1
    if args.as_status == "PASS":
        problems = _pass_problems(root, task)
        if problems:
            for problem in problems:
                print("  - %s" % problem, file=sys.stderr)
            return fail(
                "CLOSE DENIED — PASS lacks evidence (%d problem(s))"
                % len(problems)
            )
    store = C.repo_state_dir(root)
    task_id = task["task_id"]
    tdir = C.task_dir(root, task_id)
    state = dict(task["state"])
    state["lifecycle"] = "TERMINAL"
    state["terminal_status"] = args.as_status
    state["closed_at"] = C.utc_now()
    state["evidence_chain_head"] = C.chain_head(os.path.join(tdir, C.EVIDENCE_FILE))
    if args.reason:
        state["terminal_reason"] = args.reason
    C.atomic_write_json(os.path.join(tdir, "state.json"), state)
    details = []
    if args.as_status == "PASS":
        closed = dict(task)
        closed["state"] = state
        attestation_path = os.path.join(tdir, "attestation", "attestation.json")
        try:
            C.atomic_write_json(attestation_path, _build_attestation(root, closed))
            details.append("cgel: attestation exported to %s" % attestation_path)
        except Exception as exc:
            C._debug("close:attest", exc)
            details.append("cgel: attestation export failed (non-fatal)")
    # The draft slot frees up with the task: a stale contract.json squatting
    # in .task/ blocked the NEXT task more than once in real use. The sealed
    # copy lives in the state store; deleting the mirror loses nothing.
    for draft_path in _draft_paths(root):
        try:
            draft = C.load_json(draft_path)
        except Exception:
            continue
        if isinstance(draft, dict) and (draft.get("task") or {}).get("id") == task_id:
            try:
                os.unlink(draft_path)
                details.append(
                    "cgel: removed draft %s (sealed copy stays in the store)."
                    % os.path.relpath(draft_path, root)
                )
            except OSError as exc:
                C._debug("close:draft", exc)
    dirty = _dirty_paths_intersecting_scope(
        root, task["sealed"]["contract"]["scope"]["allowed"]
    )
    if dirty:
        details.append(
            "cgel: %d uncommitted file(s) remain inside this task's scope — "
            "commit or discard them, or the next seal will trip over them."
            % len(dirty)
        )
    try:  # legacy pointer from pre-multi-task versions
        os.unlink(os.path.join(store, "CURRENT"))
    except OSError as exc:
        C._debug("close:CURRENT", exc)
    return ok("CLOSE OK — %s -> %s" % (task_id, args.as_status), *details)


def cmd_schema(args):
    """Print a shipped schema so nobody hunts the plugin cache for it —
    the cache path changes every release and defeated everyone's memory."""
    path = os.path.join(PLUGIN_ROOT, "schemas", "%s.schema.json" % args.name)
    try:
        with open(path, encoding="utf-8") as fh:
            body = fh.read()
    except OSError:
        return fail("SCHEMA DENIED — unknown schema '%s'" % args.name)
    print(body, end="" if body.endswith("\n") else "\n")
    return ok("SCHEMA OK — %s" % args.name)


def _add_task_arg(parser):
    parser.add_argument(
        "--task",
        default="",
        help="task id; required only when several tasks are open",
    )


def _add_contract_arg(parser):
    parser.add_argument(
        "--contract",
        default="",
        help="contract draft path (default .task/contract.json; parallel "
        "drafts live at .task/<id>.contract.json)",
    )


def _dispatch():
    parser = argparse.ArgumentParser(prog="cgel", add_help=True)
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("init", help="create .cgel/ and .task/ (activates the gate)")
    p_validate = sub.add_parser("validate", help="validate the contract draft")
    _add_contract_arg(p_validate)
    p_summary = sub.add_parser(
        "summary",
        help="validate + print normalized contract summary + digest "
        "(no separate `cgel validate` needed)",
    )
    _add_contract_arg(p_summary)

    p_seal = sub.add_parser("seal", help="seal the drafted contract")
    p_seal.add_argument("task_id")
    p_seal.add_argument("--digest", required=True, help="exact digest from `cgel summary`")
    p_seal.add_argument(
        "--allow-dirty",
        action="store_true",
        help="user-confirmed: task may build on uncommitted changes in scope",
    )
    _add_contract_arg(p_seal)

    p_status = sub.add_parser(
        "status", help="lifecycle status (all open tasks, or --task <id>)"
    )
    _add_task_arg(p_status)

    p_verify = sub.add_parser(
        "verify",
        help="run registered check(s) and record hash-chained evidence",
    )
    p_verify.add_argument("check_ids", nargs="*", metavar="check_id")
    p_verify.add_argument(
        "--required",
        action="store_true",
        help="also run every check the contract's criteria require",
    )
    _add_task_arg(p_verify)

    p_iter = sub.add_parser("iterate", help="open or decide a loop iteration")
    iter_sub = p_iter.add_subparsers(dest="iter_command")
    p_open = iter_sub.add_parser("open", help="open the next iteration")
    p_open.add_argument("--hypothesis", default="")
    p_open.add_argument(
        "--intended-change", "--change", dest="intended_change", default=""
    )
    p_open.add_argument(
        "--expected-checks", "--expect", "--checks",
        dest="expected_checks", default="",
        help="comma-separated check ids expected to move",
    )
    _add_task_arg(p_open)
    p_decide = iter_sub.add_parser("decide", help="close the open iteration")
    p_decide.add_argument(
        "decision",
        help="ADVANCE|RETRY|REPLAN|ROLLBACK_ITERATION (unique prefixes work)",
    )
    p_decide.add_argument("--lesson", default="")
    p_decide.add_argument("--override-reason", dest="override_reason", default="")
    p_decide.add_argument("--approved-by", dest="approved_by", default="")
    p_decide.add_argument(
        "--verify",
        action="store_true",
        help="freshly run this iteration's expected checks first (one "
        "roundtrip instead of verify-then-decide)",
    )
    _add_task_arg(p_decide)

    p_unblock = sub.add_parser(
        "unblock",
        help="USER action: lift a budget/environment block, or widen a "
        "budget before it runs out",
    )
    p_unblock.add_argument("--add-iterations", dest="add_iterations", type=int, default=0)
    p_unblock.add_argument("--add-replans", dest="add_replans", type=int, default=0)
    # `--reason` used to be accepted here and read by nothing: the user typed
    # a justification into a flag that went nowhere, and an approval question
    # quoting it approved a string with no effect. Rejecting it out loud beats
    # accepting it silently. (`cgel close --reason` is real and unaffected.)
    _add_task_arg(p_unblock)

    p_check = sub.add_parser(
        "check", help="manage the verification registry (between tasks only)"
    )
    check_sub = p_check.add_subparsers(dest="check_command")
    p_check_add = check_sub.add_parser(
        "add", help="register a check (denied while a task is open)"
    )
    p_check_add.add_argument("check_id")
    # dest must not collide with the top-level subcommand dest "command"
    p_check_add.add_argument("--command", dest="check_command_str", required=True)
    p_check_add.add_argument(
        "--kind", default="", help="test|build|compile|lint|typecheck|security|eval"
    )
    p_check_add.add_argument("--timeout", type=int, default=0, help="seconds (default 600)")
    p_check_add.add_argument("--workdir", default="")
    p_check_add.add_argument(
        "--watch",
        default="",
        help="comma-separated globs: evidence from this check only goes "
        "stale when a changed path matches one (default: any change)",
    )
    p_check_add.add_argument("--force", action="store_true")
    p_check_add.add_argument(
        "--allow-unproven",
        action="store_true",
        help="register even though the command passes with no project present",
    )
    check_sub.add_parser("list", help="list registered checks")
    check_sub.add_parser(
        "doctor",
        help="re-test every check from both sides — catches checks that rotted",
    )
    p_check_remove = check_sub.add_parser(
        "remove", help="remove a check (denied while a task is open)"
    )
    p_check_remove.add_argument("check_id")

    sub.add_parser("rules", help="list semantic rules parsed from docs/standards")

    p_sem = sub.add_parser("semantic", help="record verifier findings")
    sem_sub = p_sem.add_subparsers(dest="semantic_command")
    p_sem_rec = sem_sub.add_parser(
        "record", help="validate + chain a findings JSON file"
    )
    p_sem_rec.add_argument(
        "--file", default="", help="findings JSON (default .task/findings.json)"
    )
    _add_task_arg(p_sem_rec)

    p_attest = sub.add_parser("attest", help="export a sanitized attestation")
    _add_task_arg(p_attest)

    p_audit = sub.add_parser(
        "audit", help="verify evidence chains, seal bindings, governance bundle"
    )
    _add_task_arg(p_audit)

    p_schema = sub.add_parser(
        "schema", help="print a shipped schema (task-contract, evidence, ...)"
    )
    p_schema.add_argument(
        "name",
        choices=["task-contract", "evidence", "findings", "attestation"],
    )

    p_close = sub.add_parser("close", help="close an open task")
    p_close.add_argument(
        "--as",
        dest="as_status",
        required=True,
        choices=["ROLLED_BACK", "ESCALATE", "ABORT", "PASS"],
    )
    p_close.add_argument("--reason", default="")
    _add_task_arg(p_close)

    args = parser.parse_args()
    handlers = {
        "init": cmd_init,
        "validate": cmd_validate,
        "summary": cmd_summary,
        "seal": cmd_seal,
        "status": cmd_status,
        "verify": cmd_verify,
        "audit": cmd_audit,
        "iterate": cmd_iterate,
        "unblock": cmd_unblock,
        "check": cmd_check,
        "rules": cmd_rules,
        "semantic": cmd_semantic,
        "attest": cmd_attest,
        "schema": cmd_schema,
        "close": cmd_close,
    }
    if args.command not in handlers:
        parser.print_usage(sys.stderr)
        print("ERROR usage")
        return 3
    return handlers[args.command](args)


def main():
    """Guarantee the output contract this file's docstring promises.

    Every caller — the skills, the hooks, the tests — reads the last line of
    stdout. An unhandled exception used to break that contract silently: a
    traceback on stderr, nothing parseable on stdout, and a caller that
    cannot tell "denied" from "crashed". SystemExit is re-raised so
    require_repo_root's exit(3) and argparse's own exits are unchanged."""
    try:
        return _dispatch()
    except SystemExit:
        raise
    except KeyboardInterrupt:
        print("cgel: interrupted.", file=sys.stderr)
        print("ERROR interrupted")
        return 1
    except Exception as exc:  # noqa: BLE001 — the decision line is the contract
        if os.environ.get("CGEL_DEBUG"):
            traceback.print_exc()
        else:
            print(
                "cgel: internal error: %s: %s" % (type(exc).__name__, exc),
                file=sys.stderr,
            )
            print(
                "cgel: re-run with CGEL_DEBUG=1 for the traceback.",
                file=sys.stderr,
            )
        print("ERROR internal-error")
        return 1


if __name__ == "__main__":
    sys.exit(main())
